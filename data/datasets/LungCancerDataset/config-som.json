{
    "map_size": [20, 20],
    "start_learning_rate": 0.75,
    "end_learning_rate": 0.01,
    "lr_decay_type": "exp-drop",

    "start_radius_init_ratio": 1.0,
    "end_radius": 1.0,
    "radius_decay_type": "linear-drop",

    "start_batch_percent": 0.0001,
    "end_batch_percent": 0.0001,
    "batch_growth_type": "static",

    "epoch_multiplier": 200.0,
    "normalize_weights_flag": false,
    "growth_g": 35,
    "random_seed": 42,
    "map_type": "hex",
    "num_batches": 1,
    "max_epochs_without_improvement": 500,
    "mqe_evaluations_per_run": 300,
    "save_checkpoints": true,
    "checkpoint_every_mqe": false,
    "checkpoint_count": 300,

    "delimiter": ",",
    "categorical_threshold_numeric": 30,
    "noise_threshold_ratio": 0.2,
    "categorical_threshold_text": 30,
    "primary_id": "id",

    "NEURAL_NETWORKS": {
        "use_lstm": false,
        "lstm_model_path": "app/lstm/models/lstm_latest.keras",
        "lstm_scaler_path": "app/lstm/models/lstm_scaler_latest.pkl",
        "lstm_quality_threshold": 0.75
    }
}
