{
  "_comment": "Pareto front visualization run — fast mode. mqe_evaluations_per_run=40 gives ~6x speedup vs 300 while preserving early stopping and initial_mqe. checkpoint_every_mqe=false keeps disk I/O low.",

  "use_nn": false,
  "EA_SETTINGS": {
    "population_size": 30,
    "generations": 20,
    "seeds": [42]
  },
  "SEARCH_SPACE": {
    "map_size": {
      "type": "discrete_int_pair"
    },
    "start_learning_rate": {
      "type": "float",
      "min": 0.5,
      "max": 1.0,
      "log_scale": true
    },
    "end_learning_rate": {
      "type": "float",
      "min": 0.001,
      "max": 0.2,
      "log_scale": true
    },
    "lr_decay_type": {
      "type": "categorical",
      "values": ["linear-drop", "exp-drop", "step-down"]
    },
    "radius_decay_type": {
      "type": "categorical",
      "values": ["linear-drop", "exp-drop", "step-down"]
    },
    "start_batch_percent": {
      "type": "float",
      "min": 0.0,
      "max": 3.0
    },
    "end_batch_percent": {
      "type": "float",
      "min": 1.0,
      "max": 8.0
    },
    "batch_growth_type": {
      "type": "categorical",
      "values": ["linear-growth", "exp-growth"]
    },
    "epoch_multiplier": {
      "type": "float"
    },
    "growth_g": {
      "type": "int",
      "min": 10,
      "max": 40
    },
    "num_batches": {
      "type": "int",
      "min": 1,
      "max": 10
    }
  },
  "GENETIC_OPERATORS": {
    "sbx_eta": 20.0,
    "mutation_eta": 20.0,
    "mutation_prob": 0.1,
    "crossover_prob": 0.9,
    "tournament_k": 5
  },
  "FIXED_PARAMS": {
    "start_radius_init_ratio": 1.0,
    "end_radius": 1.0,
    "random_seed": 42,
    "max_archive_size": 25,
    "mqe_evaluations_per_run": 40,
    "map_type": "hex",
    "save_checkpoints": true,
    "checkpoint_every_mqe": false,
    "checkpoint_count": 5,
    "early_stopping_window": 10,
    "max_epochs_without_improvement": 150,
    "normalize_weights_flag": false,
    "generate_individual_maps": false
  },
  "NEURAL_NETWORKS": {
    "use_mlp": false,
    "use_lstm": false,
    "use_cnn": false,
    "use_lstm_controller": false,
    "mlp_model_path": "app/mlp/models/mlp_latest.keras",
    "mlp_scaler_path": "app/mlp/models/mlp_scaler_latest.pkl",
    "lstm_model_path": "app/lstm/models/lstm_latest.keras",
    "lstm_scaler_path": "app/lstm/models/lstm_scaler_latest.pkl",
    "cnn_model_path": null,
    "lstm_controller_model_path": "app/lstm/models/lstm_controller_latest.keras",
    "lstm_controller_scaler_path": "app/lstm/models/lstm_controller_scaler_latest.pkl",
    "lstm_quality_threshold": 0.75,
    "mlp_filter_bad_configs": false,
    "mlp_bad_quality_threshold": 0.5,
    "verbose": true
  },
  "PREPROCES_DATA": {
    "delimiter": ",",
    "categorical_threshold_numeric": 30,
    "noise_threshold_ratio": 0.2,
    "categorical_threshold_text": 30,
    "primary_id": "id"
  }
}
