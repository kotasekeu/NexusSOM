{
  "use_nn": false,
  "EA_SETTINGS": {
    "population_size": 20,
    "generations": 30
  },
  "SEARCH_SPACE": {
    "map_size": {
      "type": "discrete_int_pair",
      "min": 3,
      "max": 8
    },
    "start_learning_rate": {
      "type": "float",
      "min": 0.1,
      "max": 0.9,
      "log_scale": true
    },
    "end_learning_rate": {
      "type": "float",
      "min": 0.005,
      "max": 0.3,
      "log_scale": true
    },
    "lr_decay_type": {
      "type": "categorical",
      "values": ["linear-drop", "exp-drop", "log-drop", "step-down"]
    },
    "start_radius_init_ratio": {
      "type": "float",
      "min": 0.05,
      "max": 1.0,
      "log_scale": true
    },
    "radius_decay_type": {
      "type": "categorical",
      "values": ["linear-drop", "exp-drop", "log-drop", "step-down"]
    },
    "start_batch_percent": {
      "type": "float",
      "min": 0.5,
      "max": 5.0
    },
    "end_batch_percent": {
      "type": "float",
      "min": 2.0,
      "max": 10.0
    },
    "batch_growth_type": {
      "type": "categorical",
      "values": ["linear-growth", "exp-growth", "log-growth"]
    },
    "epoch_multiplier": {
      "type": "int",
      "min": 1,
      "max": 5
    },
    "normalize_weights_flag": {
      "type": "categorical",
      "values": [false, true]
    },
    "growth_g": {
      "type": "int",
      "min": 10,
      "max": 30
    },
    "num_batches": {
      "type": "int",
      "min": 1,
      "max": 5
    }
  },
  "GENETIC_OPERATORS": {
    "sbx_eta": 20.0,
    "mutation_eta": 20.0,
    "mutation_prob": 0.1,
    "crossover_prob": 0.9
  },
  "FIXED_PARAMS": {
    "end_radius": 1.0,
    "random_seed": 42,
    "mqe_evaluations_per_run": 200,
    "map_type": "hex",
    "max_epochs_without_improvement": 30,
    "early_stopping_window": 5,
    "save_checkpoints": true,
    "checkpoint_count": 10
  },
  "NEURAL_NETWORKS": {
    "use_mlp": false,
    "use_lstm": false,
    "use_cnn": false,
    "mlp_model_path": null,
    "mlp_scaler_path": null,
    "lstm_model_path": null,
    "cnn_model_path": null,
    "lstm_quality_threshold": 1.0,
    "mlp_filter_bad_configs": false,
    "mlp_bad_quality_threshold": 0.5,
    "verbose": false
  },
  "PREPROCES_DATA": {
    "delimiter": ",",
    "categorical_threshold_numeric": 30,
    "noise_threshold_ratio": 0.2,
    "categorical_threshold_text": 30,
    "primary_id": "id"
  }
}
